{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.spec.json"
      }
    ]
  },
  "collectCoverageFrom": ["src/**/*.ts", "!src/cli/**"],
  "coverageDirectory": "./coverage",
  "testEnvironment": "node"
}
